# ─── Base de datos (PostgreSQL) ───────────────────────────────────────────────
POSTGRES_DB=soccerstyle
POSTGRES_USER=soccerstyle_admin
POSTGRES_PASSWORD=cambia_esto_por_una_password_segura
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera un valor seguro: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=cambia_esto_por_un_secreto_seguro
JWT_EXPIRATION_HOURS=8

# ─── Admin inicial ────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@tusitio.com
ADMIN_PASSWORD=cambia_esto_por_una_password_segura
ADMIN_NOMBRE=Administrador

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dominio(s) del frontend separados por coma. Usa * solo en desarrollo.
ALLOWED_ORIGINS=https://soccerstyle.com.ec,https://www.soccerstyle.com.ec

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
EMAIL_ADDRESS=tucorreo@gmail.com
EMAIL_PASSWORD=tu_app_password_de_gmail
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
MAIL_SENDER=tucorreo@gmail.com
MAIL_RECIPIENT=destino@tusitio.com

# ─── Subida de archivos ───────────────────────────────────────────────────────
# Tamaño máximo en bytes (por defecto 5 MB)
MAX_CONTENT_LENGTH=5242880
